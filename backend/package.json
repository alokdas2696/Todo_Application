{
  "name": "todo-backend",
  "version": "1.0.0",
  "description": "Production-ready MVC/Repository pattern Todo application backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "sequelize db:migrate",
    "db:seed": "sequelize db:seed:all",
    "db:migrate:undo": "sequelize db:migrate:undo:all",
    "db:seed:undo": "sequelize db:seed:undo:all",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.10.1",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "eslint": "^9.5.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "sequelize-cli": "^6.6.2"
  }
}
